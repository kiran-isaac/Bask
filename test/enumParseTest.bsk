struct Vector2 (
  float x,
  float y,
).{
  fn length() -> float {
    return sqrt(x * x + y * y);
  }

  fn normalized() -> Vector2 {
    float len = length();
    return new(x / len, y / len);
  }

  fn mut normalize() {
    float len = length();
    x = x / len;
    y = y / len;
  }
}